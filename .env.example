# Marketplace API — runtime configuration.
# Copy to .env and fill in real values. Never commit your real .env.

# Public Google OAuth 2.0 client ID (NOT a secret — this value is shipped to browsers).
# Get one at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Path to the Ed25519 issuer keypair used to sign Agent Passports and session JWTs.
# In docker-compose this is mounted into the container at /app/minimal-issuer/keys/issuer.json.
ISSUER_KEYS_PATH=./minimal-issuer/keys/issuer.json

# Audience claim required on session JWTs and Agent Passports.
AUDIENCE=marketplace.dev

# Listen address inside the process. In Docker this should be 0.0.0.0.
HOST=127.0.0.1
PORT=3100

# Optional. Set to "1" to bypass DPoP/passport verification on agent routes
# (synthetic principal from x-mp-agent-id header). Local dev only — never in prod.
DEV_BYPASS=0

# Logging level for the Fastify pino logger.
LOG_LEVEL=info

# PostgreSQL connection string used by @marketplace/db (drizzle-kit + the API at runtime).
# Default matches the docker-compose `postgres` service. When running the API outside
# Docker against the compose Postgres, swap `postgres` for `localhost`.
DATABASE_URL=postgres://marketplace:marketplace@localhost:5432/marketplace

# Optional. Redis connection string used for snapshot storage (spec §8.4) with a 24h TTL.
# When unset, the API falls back to an in-memory snapshot store (process-local, lost on restart).
# Default below matches the docker-compose `redis` service when the API runs outside Docker.
# REDIS_URL=redis://localhost:6379

# Optional. Public web origin used to build human-shareable snapshot links
# (`{base}/s/{id}`) returned alongside catalog reads on both MCP tools and the
# REST endpoints `GET /v1/products` and `GET /v1/products/{id}`. When unset,
# snapshots are still written but the response omits `snapshotUrl`.
# Production: https://teno-store.com
# MARKETPLACE_WEB_BASE_URL=http://localhost:3200
