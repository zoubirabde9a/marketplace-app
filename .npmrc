engine-strict=true
auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false

# pnpm 10.0+ refuses to install when transitive deps have build scripts that
# aren't explicitly approved (ERR_PNPM_IGNORED_BUILDS for esbuild, sharp).
# package.json `pnpm.onlyBuiltDependencies` IS set but isn't being honored
# by the docker build environment for some reason — install still errors.
# Probed in production 2026-05-11: `docker compose build web` failed on
# `pnpm install --no-frozen-lockfile` with esbuild@0.18/0.19/0.27 + sharp@0.34
# listed as ignored. dangerously-allow-all-builds bypasses the error; for
# our internal docker build pipeline this is safe (lockfile is checked
# into git, we trust the deps we use).
dangerously-allow-all-builds=true
