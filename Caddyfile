# Caddyfile for teno-store.com — production reverse proxy.
#
# Caddy auto-issues Let's Encrypt certs for every site block on first start
# and auto-renews. HTTP→HTTPS redirect is automatic. HTTP/2 + HTTP/3 enabled
# by default. No manual cert wrangling.
#
# DNS layout (managed in Cloudflare, see deploy/dns.md):
#   teno-store.com        → human/agent-readable web (Next.js observer)
#   www.teno-store.com    → 301 redirect to apex
#   api.teno-store.com    → REST/MCP/A2A endpoints (Fastify)
#
# Cloudflare is DNS-only (gray cloud) — proxied mode adds unacceptable latency
# from Algerian residential connections, so traffic hits Caddy directly. That
# means caching, rate limiting, and abuse mitigation all happen here at the
# origin — there is no edge layer in front.

{
	email mahlledz@gmail.com

	# HTTP response cache (Souin via caddyserver/cache-handler). Honors
	# Cache-Control: s-maxage / stale-while-revalidate from upstream
	# responses. Next.js sets these on /c/*, /product/*, /feed.xml, and
	# /_next/image, so most SSR work is collapsed to one upstream hit per
	# (URL, vary-key) until the TTL expires. In-memory storage — lost on
	# Caddy restart, but rebuilds within seconds under normal traffic and
	# avoids managing another on-disk volume.
	cache {
		ttl 5m
		stale 1h
		default_cache_control "public"
	}

	# Rate limit module ordering — runs before reverse_proxy and cache so
	# 429s are emitted without engaging upstream or filling cache slots.
	order rate_limit before basic_auth
}

# ─── Apex: human-readable observer (Next.js) ─────────────────────────────────
teno-store.com {
	encode zstd gzip

	# Cache eligible responses (apex-wide). Decision is driven by the
	# upstream Cache-Control header — endpoints that mark themselves
	# `private` / `no-store` (e.g. checkout, /api/auth/*) bypass.
	cache

	# Throttle SSR-heavy paths per client IP. /_next/image, /_next/static,
	# /sitemap*.xml, /robots.txt, /favicon.ico are intentionally NOT limited:
	# they're either cache hits or static disk reads. The 60/min/IP target
	# is comfortable for a fast human (clicking ~1 page/sec) but cuts off
	# the 2026-05-17 scraper that hit 70 req/5min purely on /c/* /product/*.
	rate_limit {
		zone ssr_pages {
			match {
				path /c/* /product/* /search* /feed.xml /b/*
			}
			key {client_ip}
			events 60
			window 1m
		}
	}

	# Pre-generated sitemap files (built by marketplace-sitemap-rebuild.timer,
	# every 30 min) live in /srv/sitemaps mounted from
	# /opt/marketplace/data/sitemaps. Serving them statically here keeps the
	# 17 MB/50k-URL payload off the Next.js render path — previously a cold
	# /sitemap.xml hit pinned the origin for ~120 s. The @sitemap_file matcher
	# only fires when the requested file actually exists on disk; otherwise
	# the request falls through to the Next.js reverse_proxy below, which
	# still knows how to render a sitemap from the API (fresh-deploy fallback,
	# local dev).
	@sitemap_file {
		path /sitemap.xml /sitemap-*.xml
		file {
			root /srv/sitemaps
		}
	}
	handle @sitemap_file {
		root * /srv/sitemaps
		header Cache-Control "public, s-maxage=3600, stale-while-revalidate=86400"
		header Content-Type "application/xml; charset=utf-8"
		file_server
	}

	reverse_proxy web:3200 {
		# Bridge the ~3-5s gap when `docker compose up -d --build web`
		# recreates the upstream during a deploy. Without this, anyone who
		# clicks Add-to-cart, Checkout, or any Next.js Server Action POST
		# inside that window gets a hard 502 (we saw a wave of these on
		# the 2026-05-11 cart deploy). lb_try_duration tells Caddy to keep
		# retrying connect-refused / dial errors against this backend for
		# up to 30 s, polling every 250 ms.
		lb_try_duration 30s
		lb_try_interval 250ms
		# Server-action POSTs (form submits from /cart, /checkout) carry a
		# small multipart payload. To retry those after a connect error,
		# Caddy needs the body buffered — otherwise the retry attempt
		# would have no body to resend. 4 MB is well over any server-
		# action payload (the cart/checkout forms are < 1 KB) and well
		# under any real media upload (which goes to api.teno-store.com,
		# not here).
		request_buffers 4MB
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin-when-cross-origin"
		X-Frame-Options "SAMEORIGIN"
		Permissions-Policy "geolocation=(), microphone=(), camera=()"
		-Server
	}

	log {
		output stdout
		format json
	}
}

# ─── www → apex ─────────────────────────────────────────────────────────────
www.teno-store.com {
	redir https://teno-store.com{uri} permanent
}

# ─── API subdomain: REST + (future) MCP / A2A endpoints (Fastify) ───────────
api.teno-store.com {
	encode zstd gzip

	# Generic abuse cap on the API. Real clients (web SSR, MCP agents,
	# authenticated browsers) burst much higher than 300/min in normal use,
	# so this is a safety net against probing — not a fairness limit. Tune
	# down if a specific endpoint (e.g. /mcp) needs tighter control.
	rate_limit {
		zone api_per_ip {
			key {client_ip}
			events 300
			window 1m
		}
	}

	reverse_proxy api:3100 {
		# Same recreate-gap mitigation as the apex (see comment there).
		# No request buffering: this backend serves media uploads and we
		# don't want to balloon Caddy memory on large multipart POSTs.
		# Retries only protect idempotent paths in practice, but that
		# covers the bulk of /v1/products, /v1/cart GETs etc. that the
		# web tier fetches during SSR.
		lb_try_duration 30s
		lb_try_interval 250ms
	}

	header {
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		X-Content-Type-Options "nosniff"
		Referrer-Policy "strict-origin"
		# Allow agent clients (browsers, MCP clients running in browser tabs)
		# to talk to api.teno-store.com from any origin. Refine if/when we
		# add cookie-based auth on this subdomain.
		Access-Control-Allow-Origin "*"
		Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
		# Request headers cross-origin clients can SEND. Beyond the basic
		# auth set, two are mandatory for write paths:
		# - Idempotency-Key: required by mutation middleware on every POST/
		#   PATCH/DELETE. Without it in Allow-Headers, browser preflight on
		#   any seller-dashboard write fails before the request goes out.
		# - X-Mp-Order-Token: used for token-based order-detail access
		#   (anonymous checkout receipt links).
		Access-Control-Allow-Headers "Content-Type, Authorization, DPoP, X-Mp-Agent-Id, Idempotency-Key, X-Mp-Order-Token, X-Mp-Mcp-Token"
		# Custom response headers that cross-origin browser JS must be able
		# to READ. Without this, fetch().headers.get('x-mp-cart-id') returns
		# null even when the header is on the wire (CORS-safelisted headers
		# like Content-Type / Cache-Control / ETag are accessible by
		# default; everything else needs explicit exposure).
		Access-Control-Expose-Headers "X-Mp-Cart-Id, X-Request-Id"
		Access-Control-Max-Age "86400"
		-Server
	}

	@options method OPTIONS
	respond @options 204

	log {
		output stdout
		format json
	}
}
