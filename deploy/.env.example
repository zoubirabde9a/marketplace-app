# deploy/.env — secrets used during provisioning and ad-hoc ops.
# Copy this file to deploy/.env and fill in real values. Never commit deploy/.env.
#
# Note: this is the operator's *bootstrap* secret store. Runtime app secrets
# (DATABASE_URL, ISSUER_KEYS_PATH, GOOGLE_CLIENT_ID, etc.) live in the project
# root .env and on the server itself — see /.env.example.

# ─── vps-eu (netcup, Nuremberg) ────────────────────────────────────────────
# Initial root password issued by netcup at provisioning time.
# Policy: password auth stays enabled on the server as a recovery path,
# so this value is the canonical record of root's password. Update it here
# whenever the password is rotated on the server.
VPS_EU_ROOT_PASSWORD=

# Provider control panel password (if different from the OS root password).
# Used to access netcup's customer area / SCP for OOB recovery.
VPS_EU_PROVIDER_PASSWORD=

# ─── Backups (Backblaze B2 via restic) ─────────────────────────────────────
# Filled in once we set up B2. See protocols.md → Backups.
RESTIC_REPOSITORY=
RESTIC_PASSWORD=
B2_ACCOUNT_ID=
B2_ACCOUNT_KEY=

# ─── Cloudflare (DNS / proxy) ──────────────────────────────────────────────
# API token scoped to "Edit DNS records" on our domain only.
# Created at https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# ─── GitHub Container Registry ─────────────────────────────────────────────
# Personal Access Token (classic) with `read:packages` so the server can pull
# private app images. Username is the GitHub login.
GHCR_USERNAME=
GHCR_TOKEN=
