{
  "name": "@marketplace/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./schema": "./dist/schema/index.js",
    "./schema/*": "./dist/schema/*.js",
    "./client": "./dist/client.js"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "vitest run --passWithNoTests",
    "test:unit": "vitest run --passWithNoTests",
    "typecheck": "tsc -b",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/migrate.ts",
    "db:seed": "tsx src/seed.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@marketplace/domain": "workspace:*",
    "@marketplace/shared": "workspace:*",
    "drizzle-orm": "catalog:",
    "postgres": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "drizzle-kit": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:",
    "tsx": "catalog:",
    "@types/node": "catalog:"
  }
}
