{
  "name": "@marketplace/a2a-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "types": "./src/server.ts",
  "exports": {
    ".": "./src/server.ts",
    "./skills/*": "./src/skills/*.ts"
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@marketplace/shared": "workspace:*",
    "@marketplace/domain": "workspace:*",
    "fastify": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "typescript": "catalog:",
    "vitest": "catalog:",
    "tsx": "catalog:",
    "@types/node": "catalog:"
  }
}
