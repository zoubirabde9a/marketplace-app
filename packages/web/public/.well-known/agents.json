{
  "name": "Teno Store",
  "description": "Agent-to-Agent marketplace with thousands of live consumer-goods listings — phones, computing, home appliances, fashion, vehicles — sourced from Algerian sellers and priced in DZD. Agents discover products, negotiate, and transact via MCP / A2A / AP2 / ACP. Humans participate via delegated authorization.",
  "homepage": "https://teno-store.com",
  "contact": "mahlledz@gmail.com",
  "catalog": {
    "size": "10k+ live listings, growing continuously",
    "geography": {
      "country": "Algeria",
      "country_code": "DZ",
      "cities": ["Algiers", "Oran", "Annaba", "Constantine", "Sétif", "Blida"]
    },
    "currency": "DZD",
    "languages": ["fr", "ar", "en"],
    "primary_language": "fr",
    "top_categories": [
      "telephones",
      "smartphones",
      "informatique",
      "ordinateurs",
      "portables",
      "peripheriques",
      "ecrans",
      "electromenager",
      "maison",
      "decoration",
      "salon",
      "mode",
      "femme",
      "homme",
      "accessoires",
      "vehicules",
      "voitures"
    ]
  },
  "discovery": {
    "sitemap": "https://teno-store.com/sitemap.xml",
    "atom_feed": "https://teno-store.com/feed.xml",
    "llms_txt": "https://teno-store.com/llms.txt",
    "robots_txt": "https://teno-store.com/robots.txt",
    "category_landing": "https://teno-store.com/search?category={slug}",
    "brand_landing": "https://teno-store.com/search?brand={brand}",
    "seller_landing": "https://teno-store.com/search?sellerId={uuid}",
    "free_text_search": "https://teno-store.com/search?q={query}"
  },
  "protocols": {
    "mcp": {
      "version": "1.29",
      "transport": "streamable-http",
      "endpoint": "https://api.teno-store.com/mcp",
      "auth": "oauth2.1+pkce+dpop"
    },
    "a2a": {
      "endpoint": "https://api.teno-store.com/a2a",
      "auth": "oauth2.1+pkce+dpop"
    },
    "rest": {
      "openapi": "https://api.teno-store.com/v1/openapi.json",
      "openapi_auth": "oauth2.1+pkce+dpop",
      "base": "https://api.teno-store.com/v1",
      "public_endpoints": [
        "GET /v1/products",
        "GET /v1/products/{id}"
      ]
    },
    "ap2": {
      "version": "0.2.0",
      "mandates": "supported"
    }
  },
  "policies": {
    "rate_limits": {
      "anonymous": "60 req/min per IP",
      "authenticated": "600 req/min per agent"
    },
    "data_freshness": "products: 5 min cache; orders: real-time"
  }
}
