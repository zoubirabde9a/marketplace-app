{
  "name": "@marketplace/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "dev": "tsx watch --conditions=development src/start.ts",
    "start": "tsx --conditions=development src/start.ts",
    "demo": "tsx --conditions=development src/demo.ts",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:contract": "vitest run --dir test/contract",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/swagger": "^9.0.0",
    "@marketplace/db": "workspace:*",
    "@marketplace/domain": "workspace:*",
    "@marketplace/mcp-server": "workspace:*",
    "@marketplace/shared": "workspace:*",
    "dotenv": "^16.4.0",
    "fastify": "catalog:",
    "ioredis": "catalog:",
    "jose": "^6.0.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
